<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simple Calculator"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/displayTextView"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="0"
        android:textSize="32sp"
        android:gravity="right"
        android:padding="16dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="16dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="4"
        android:rowCount="5"
        android:columnCountPortrait="4">

        <Button android:id="@+id/btn7" android:text="7" android:textSize="20sp"
            android:layout_row="0" android:layout_column="0" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn8" android:text="8" android:textSize="20sp"
            android:layout_row="0" android:layout_column="1" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn9" android:text="9" android:textSize="20sp"
            android:layout_row="0" android:layout_column="2" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnDivide" android:text="/" android:textSize="20sp"
            android:layout_row="0" android:layout_column="3" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn4" android:text="4" android:textSize="20sp"
            android:layout_row="1" android:layout_column="0" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn5" android:text="5" android:textSize="20sp"
            android:layout_row="1" android:layout_column="1" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn6" android:text="6" android:textSize="20sp"
            android:layout_row="1" android:layout_column="2" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnMultiply" android:text="*" android:textSize="20sp"
            android:layout_row="1" android:layout_column="3" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn1" android:text="1" android:textSize="20sp"
            android:layout_row="2" android:layout_column="0" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn2" android:text="2" android:textSize="20sp"
            android:layout_row="2" android:layout_column="1" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btn3" android:text="3" android:textSize="20sp"
            android:layout_row="2" android:layout_column="2" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnSubtract" android:text="-" android:textSize="20sp"
            android:layout_row="2" android:layout_column="3" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btn0" android:text="0" android:textSize="20sp"
            android:layout_row="3" android:layout_column="0" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnDecimal" android:text="." android:textSize="20sp"
            android:layout_row="3" android:layout_column="1" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnClear" android:text="C" android:textSize="20sp"
            android:layout_row="3" android:layout_column="2" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />
        <Button android:id="@+id/btnAdd" android:text="+" android:textSize="20sp"
            android:layout_row="3" android:layout_column="3" android:layout_columnWeight="1"
            android:layout_rowWeight="1" android:layout_gravity="fill" />

        <Button android:id="@+id/btnEqual" android:text="=" android:textSize="20sp"
            android:layout_row="4" android:layout_column="0" android:layout_columnWeight="4"
            android:layout_rowWeight="1" android:layout_gravity="fill" />

    </GridLayout>

</LinearLayout>
